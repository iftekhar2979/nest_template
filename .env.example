# App Environment
NODE_ENV=development
PORT=8080
FR_BASE_URL=http://localhost:3000

# Database
# Use a MongoDB connection string
DB_URL=mongodb://localhost:27017/nest_template

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_me
EXPIRES_IN=30d

# SMTP Configuration (Email)
SMTP_USER=
SMTP_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_IP=127.0.0.1

# AWS / MinIO Configuration
# The S3Service is configured to use MinIO by default but can be used with AWS S3.
AWS_REGION=us-east-1
AWS_ACCESS_KEY=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_PUBLIC_BUCKET_NAME=quiz-app
AWS_SECRET_NAME=

# MinIO Specific (May be used interchangeably with AWS keys in some services)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Initial Admin User (Seeding)
# These values are used to create an initial admin user in the database.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword123!
ADMIN_ROLE=admin
ADMIN_NAME=Super Admin
ADMIN_PROFILE_PICTURE=
ADMIN_PHONE=

# Rate Limiting (Throttler)
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
